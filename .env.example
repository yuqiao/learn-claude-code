# API Key (required)
# Get yours at: https://platform.deepseek.com/
OPENAI_API_KEY=sk-xxx

# Model ID (required)
MODEL_ID=deepseek-chat

# API Base URL (required for compatible providers)
# LangChain/OpenAI SDK reads from OPENAI_API_BASE automatically
OPENAI_API_BASE=https://api.deepseek.com/v1

# =============================================================================
#  OpenAI-compatible providers
#
#  Provider         MODEL_ID              OPENAI_API_BASE
#  ---------------  --------------------  ------------------------------------
#  DeepSeek         deepseek-chat         https://api.deepseek.com/v1
#  Kimi (Moonshot)  moonshot-v1-8k        https://api.moonshot.cn/v1
#  GLM (Zhipu)      glm-4                 https://open.bigmodel.cn/api/paas/v4
#  Qwen (Alibaba)   qwen-turbo            https://dashscope.aliyuncs.com/compatible-mode/v1
#  OpenAI           gpt-4o                (leave OPENAI_API_BASE empty)
# =============================================================================